#!/bin/sh
set -eu

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd -P)
self_path="$script_dir/$(basename "$0")"

find_pi_safe() {
  if [ -n "${PI_SAFE_BIN:-}" ]; then
    printf '%s\n' "$PI_SAFE_BIN"
    return 0
  fi

  for candidate in "$script_dir/pi-safe" "$HOME/.local/bin/pi-safe" "/opt/homebrew/bin/pi-safe"; do
    [ -x "$candidate" ] || continue
    printf '%s\n' "$candidate"
    return 0
  done

  found=$(command -v pi-safe 2>/dev/null || true)
  if [ -n "$found" ]; then
    printf '%s\n' "$found"
    return 0
  fi

  echo "pi-safe wrapper: could not find pi-safe; set PI_SAFE_BIN=/path/to/pi-safe" >&2
  return 127
}

find_real_pi() {
  if [ -n "${PI_SAFE_REAL_PI:-}" ]; then
    printf '%s\n' "$PI_SAFE_REAL_PI"
    return 0
  fi

  for candidate in \
    "/opt/homebrew/lib/node_modules/@earendil-works/pi-coding-agent/dist/cli.js" \
    "/usr/local/lib/node_modules/@earendil-works/pi-coding-agent/dist/cli.js"
  do
    [ -x "$candidate" ] || continue
    printf '%s\n' "$candidate"
    return 0
  done

  old_ifs=$IFS
  IFS=:
  for dir in $PATH; do
    [ -n "$dir" ] || dir=.
    real_dir=$(CDPATH= cd "$dir" 2>/dev/null && pwd -P) || continue
    candidate="$real_dir/pi"
    [ -x "$candidate" ] || continue
    [ "$candidate" = "$self_path" ] && continue
    printf '%s\n' "$candidate"
    IFS=$old_ifs
    return 0
  done
  IFS=$old_ifs

  echo "pi-safe wrapper: could not find the real pi binary; set PI_SAFE_REAL_PI=/path/to/pi" >&2
  return 127
}

pi_safe_bin=$(find_pi_safe)

if [ "${1:-}" = "/sandbox" ]; then
  real_pi=$(find_real_pi 2>/dev/null || true)
  [ -n "$real_pi" ] || real_pi="(not found)"
  exec "$pi_safe_bin" status --from-wrapper --wrapper "$self_path" --pi-safe "$pi_safe_bin" --real-pi "$real_pi" --bypass "${PI_SAFE_BYPASS:-0}"
fi

real_pi=$(find_real_pi)

if [ "${PI_SAFE_BYPASS:-}" = "1" ]; then
  exec "$real_pi" "$@"
fi

exec "$pi_safe_bin" run --pi "$real_pi" -- "$@"
